# =============================================================================
# Restaurant ERP — STAGING environment template
# Inject secrets from AWS Secrets Manager / Azure Key Vault / GCP Secret Manager.
# =============================================================================

APP_NAME=Restaurant Resource Planning System
APP_ENV=staging
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json
APP_VERSION=1.0.0

API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=https://staging.example.com

DATABASE_URL=postgresql://APP_USER:CHANGE_ME@staging-db.example.com:5432/restaurant_rps
DB_POOL_SIZE=15
DB_MAX_OVERFLOW=30
DB_POOL_RECYCLE=1800
DB_STATEMENT_TIMEOUT_SECONDS=30
USE_ALEMBIC=true
ALLOW_CREATE_ALL=false
SEED_ENTERPRISE_DATA=false
SEED_LEGACY_FORECASTS=false

SECRET_KEY=CHANGE_ME_USE_SECRETS_MANAGER
JWT_ACCESS_EXPIRE_MINUTES=20
JWT_REFRESH_EXPIRE_DAYS=7

SECURITY_HEADERS_ENABLED=true
CSP_ENABLED=true
HSTS_ENABLED=true
HTTPS_REDIRECT_ENABLED=true
CSRF_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

REDIS_URL=redis://staging-redis.example.com:6379/0
REDIS_ENABLED=true
CELERY_BROKER_URL=redis://staging-redis.example.com:6379/1
CELERY_RESULT_BACKEND=redis://staging-redis.example.com:6379/2
CELERY_TASK_ALWAYS_EAGER=false

STORAGE_BACKEND=s3
S3_BUCKET=rrps-staging-uploads
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY via IAM role preferred

SENTRY_DSN=https://CHANGE_ME@sentry.io/0
SENTRY_TRACES_SAMPLE_RATE=0.2
METRICS_ENABLED=true
TRACING_ENABLED=true

BACKUP_DIR=/var/backups/rrps
BACKUP_RETENTION_DAYS=14

DEPLOYMENT_ID=staging
DEPLOYMENT_REGION=us-east-1
GIT_SHA=${GIT_SHA}
