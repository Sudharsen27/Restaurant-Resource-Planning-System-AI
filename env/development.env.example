# =============================================================================
# Restaurant ERP — DEVELOPMENT environment template
# Copy to Backend/.env or use via docker compose env_file.
# NEVER commit real secrets.
# =============================================================================

APP_NAME=Restaurant Resource Planning System
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
LOG_FORMAT=text
APP_VERSION=1.0.0

API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost,http://127.0.0.1

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/restaurant_rps
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600
USE_ALEMBIC=true
ALLOW_CREATE_ALL=false
SEED_ENTERPRISE_DATA=true
SEED_LEGACY_FORECASTS=true

SECRET_KEY=dev-only-change-me-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=14
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPER=true
PASSWORD_REQUIRE_LOWER=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=true
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=30

SECURITY_HEADERS_ENABLED=true
CSP_ENABLED=true
HSTS_ENABLED=false
HTTPS_REDIRECT_ENABLED=false
CSRF_ENABLED=false
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=200
RATE_LIMIT_WINDOW_SECONDS=60

REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true
REDIS_SESSION_TTL_SECONDS=86400
REDIS_CACHE_DEFAULT_TTL_SECONDS=300
REDIS_KEY_PREFIX=rrps

CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_MAX_RETRIES=3

STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=uploads
STORAGE_PUBLIC_BASE_URL=/uploads

SENTRY_DSN=
METRICS_ENABLED=true
TRACING_ENABLED=true

BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=7
BACKUP_VERIFY_ON_WRITE=true

DEPLOYMENT_ID=local-dev
DEPLOYMENT_REGION=local
GIT_SHA=dev
