# =============================================================================
# Restaurant ERP — TESTING environment template (CI / pytest)
# =============================================================================

APP_NAME=Restaurant Resource Planning System
APP_ENV=testing
DEBUG=true
LOG_LEVEL=WARNING
LOG_FORMAT=json
APP_VERSION=1.0.0

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/restaurant_rps_test
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
USE_ALEMBIC=true
ALLOW_CREATE_ALL=true
SEED_ENTERPRISE_DATA=false
SEED_LEGACY_FORECASTS=false

SECRET_KEY=test-secret-not-for-production
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=1

SECURITY_HEADERS_ENABLED=true
CSP_ENABLED=true
CSRF_ENABLED=false
HTTPS_REDIRECT_ENABLED=false
RATE_LIMIT_ENABLED=false

REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379/15
CELERY_BROKER_URL=redis://localhost:6379/14
CELERY_RESULT_BACKEND=redis://localhost:6379/13
CELERY_TASK_ALWAYS_EAGER=true

STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=uploads_test
METRICS_ENABLED=false
SENTRY_DSN=

BACKUP_DIR=backups_test
BACKUP_RETENTION_DAYS=1
