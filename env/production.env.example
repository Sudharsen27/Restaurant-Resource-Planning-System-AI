# =============================================================================
# Restaurant ERP — PRODUCTION environment template
# ALL secrets MUST come from a secrets manager. Do not store plaintext secrets.
# =============================================================================

APP_NAME=Restaurant Resource Planning System
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json
APP_VERSION=1.0.0

API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=https://app.example.com

# Prefer IAM / managed identity over static DB passwords where possible
DATABASE_URL=postgresql://APP_USER:FROM_SECRETS_MANAGER@prod-db.example.com:5432/restaurant_rps
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_RECYCLE=1800
DB_STATEMENT_TIMEOUT_SECONDS=30
USE_ALEMBIC=true
ALLOW_CREATE_ALL=false
SEED_ENTERPRISE_DATA=false
SEED_LEGACY_FORECASTS=false

SECRET_KEY=FROM_SECRETS_MANAGER
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=14
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPER=true
PASSWORD_REQUIRE_LOWER=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=true
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=30

SECURITY_HEADERS_ENABLED=true
CSP_ENABLED=true
HSTS_ENABLED=true
HSTS_MAX_AGE_SECONDS=31536000
HTTPS_REDIRECT_ENABLED=true
CSRF_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

REDIS_URL=rediss://prod-redis.example.com:6379/0
REDIS_ENABLED=true
REDIS_SESSION_TTL_SECONDS=86400
REDIS_CACHE_DEFAULT_TTL_SECONDS=300

CELERY_BROKER_URL=rediss://prod-redis.example.com:6379/1
CELERY_RESULT_BACKEND=rediss://prod-redis.example.com:6379/2
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_ACKS_LATE=true
CELERY_TASK_MAX_RETRIES=5

# Multi-cloud storage — pick one
STORAGE_BACKEND=s3
S3_BUCKET=rrps-prod-uploads
AWS_REGION=us-east-1
# STORAGE_BACKEND=r2
# S3_ENDPOINT_URL=https://ACCOUNT_ID.r2.cloudflarestorage.com
# STORAGE_BACKEND=azure
# AZURE_STORAGE_CONNECTION_STRING=FROM_SECRETS
# AZURE_STORAGE_CONTAINER=uploads
# STORAGE_BACKEND=gcs
# GCS_BUCKET=rrps-prod-uploads
# GCS_CREDENTIALS_JSON=FROM_SECRETS

SENTRY_DSN=FROM_SECRETS_MANAGER
SENTRY_TRACES_SAMPLE_RATE=0.05
METRICS_ENABLED=true
TRACING_ENABLED=true

BACKUP_DIR=/var/backups/rrps
BACKUP_RETENTION_DAYS=30
BACKUP_VERIFY_ON_WRITE=true

DEPLOYMENT_ID=production
DEPLOYMENT_REGION=us-east-1
GIT_SHA=${GIT_SHA}
BUILD_TIMESTAMP=${BUILD_TIMESTAMP}
