# Application
APP_NAME=Restaurant Resource Planning System
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
LOG_FORMAT=text

# Server
API_HOST=0.0.0.0
API_PORT=8000

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5178,http://127.0.0.1:5178

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/restaurant_rps
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600
DB_STATEMENT_TIMEOUT_SECONDS=0
USE_ALEMBIC=true
ALLOW_CREATE_ALL=false

# Artifact paths (optional — defaults to Backend/models and Backend/dataset/restaurant_data.csv)
# MODELS_DIR=C:/path/to/Backend/models
# DATASET_CSV_PATH=C:/path/to/Backend/dataset/restaurant_data.csv

# Security (JWT-ready; auth not enforced on routes yet)
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
SECURITY_HEADERS_ENABLED=true

# Rate limiting (off by default; in-memory — use Redis in multi-worker prod)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
