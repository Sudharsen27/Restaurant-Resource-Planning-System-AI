# Restaurant ERP — Backend environment template (Phase 12)
# Copy to .env and fill secrets. Prefer env/*.env.example overlays.

APP_NAME=Restaurant Resource Planning System
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
LOG_FORMAT=text
APP_VERSION=1.0.0

API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5178,http://127.0.0.1:5178

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/restaurant_rps
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600
DB_STATEMENT_TIMEOUT_SECONDS=0
USE_ALEMBIC=true
ALLOW_CREATE_ALL=false
SEED_ENTERPRISE_DATA=true
SEED_LEGACY_FORECASTS=true

SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=14
PASSWORD_MIN_LENGTH=8
SECURITY_HEADERS_ENABLED=true
CSP_ENABLED=true
HSTS_ENABLED=false
HTTPS_REDIRECT_ENABLED=false
CSRF_ENABLED=false
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=false

STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=uploads
STORAGE_PUBLIC_BASE_URL=/uploads

SENTRY_DSN=
METRICS_ENABLED=true
TRACING_ENABLED=true

BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=14

DEPLOYMENT_ID=local
DEPLOYMENT_REGION=local
GIT_SHA=dev
